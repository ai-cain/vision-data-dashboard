POSTGRES_DB=vision_dashboard
POSTGRES_USER=vision
POSTGRES_PASSWORD=vision
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_ADMIN_DB=postgres
BACKEND_PORT=5000
FRONTEND_PORT=5173
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-with-at-least-32-characters
ADMIN_API_KEYS=local-dev-key
AUTH_REQUIRED=false
AUTH_ALLOW_LOCAL_BYPASS=true
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=60
JWT_ISSUER=vision-data-dashboard
JWT_AUDIENCE=vision-dashboard-clients
FLASK_ENV=development
FLASK_DEBUG=1
DATABASE_URL=postgresql+psycopg://vision:vision@localhost:5432/vision_dashboard
VITE_API_BASE_URL=http://localhost:5000/api/v1
VITE_WS_EVENTS_URL=ws://localhost:5000/ws/events
